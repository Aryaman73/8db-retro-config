{
  "name": "8bitdo-kbd",
  "version": "0.0.1",
  "description": "Cross-platform configurator for 8BitDo Retro Mechanical Keyboards (incl. N Edition) over USB HID.",
  "type": "module",
  "bin": {
    "8bdkbd": "src/cli.ts"
  },
  "scripts": {
